generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model League {
  id         String   @id @default(uuid())
  externalId Int?     @unique // Used for API-Football syncing
  name       String   // e.g., "Primeira Liga"
  country    String   // e.g., "Portugal"
  season     String   // e.g., "2025/2026"
  matches    Match[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Team {
  id          String       @id @default(uuid())
  externalId  Int?         @unique // Used for API-Football syncing
  name        String       // e.g., "FC Porto"
  shortName   String       // e.g., "POR"
  stadium     String       // e.g., "Estádio do Dragão"
  players     Player[]
  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")
  events      MatchEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Player {
  id           String       @id @default(uuid())
  externalId   Int?         @unique // Used for API-Football syncing
  teamId       String
  name         String
  position     String       // e.g., "Forward", "Midfielder"
  jerseyNumber Int
  team         Team         @relation(fields: [teamId], references: [id])
  events       MatchEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([teamId])
}

model Match {
  id          String       @id @default(uuid())
  externalId  Int?         @unique // Used for API-Football syncing
  leagueId    String
  homeTeamId  String
  awayTeamId  String
  matchDate   DateTime     // Used by cron worker to trigger live polling
  status      String       // 'SCHEDULED', 'LIVE', 'FINISHED'
  homeScore   Int          @default(0)
  awayScore   Int          @default(0)
  league      League       @relation(fields: [leagueId], references: [id])
  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  events      MatchEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Crucial indexes for fast API reads
  @@index([matchDate])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([status])
}

model MatchEvent {
  id         String   @id @default(uuid())
  matchId    String
  teamId     String
  playerId   String?  // Nullable for events like a manager getting a card
  eventType  String   // 'GOAL', 'YELLOW_CARD', 'RED_CARD', 'SUBSTITUTION'
  minute     Int
  match      Match    @relation(fields: [matchId], references: [id])
  team       Team     @relation(fields: [teamId], references: [id])
  player     Player?  @relation(fields: [playerId], references: [id])
  createdAt  DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String    // Human-readable label, e.g. "Mobile App Production"
  hashedKey  String    @unique // SHA-256 hex digest of the raw key
  prefix     String    // First 8 chars of raw key for identification
  tier       String    @default("standard") // "standard" | "premium"
  rateLimit  Int       @default(1000) // Requests per hour for this key
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([isActive])
}
